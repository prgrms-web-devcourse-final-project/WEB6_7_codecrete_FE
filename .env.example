# 백엔드 JWT 시크릿(Base64URL), 서버 전용 (클라이언트에 노출 금지)
SECRET_KEY=
# 백엔드 REST API Base URL (예: http://localhost:8080)
NEXT_PUBLIC_API_BASE_URL=
# WebSocket 서버 URL (예: ws://localhost:8080/ws)
NEXT_PUBLIC_WS_URL=

# 카카오 OAuth REST API 키
NEXT_PUBLIC_KAKAO_CLIENT_ID=
# 카카오 로그인 redirect URI (카카오 콘솔에 동일하게 등록 필요)
NEXT_PUBLIC_KAKAO_REDIRECT_URI=
# 카카오 지도 JavaScript 키
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
# 카카오 지도용 API 키
NEXT_PUBLIC_KAKAO_MAP_API_KEY=

# 구글 OAuth 클라이언트 ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# 구글 로그인 redirect URI (Google Cloud Console에 동일하게 등록 필요)
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=
